{
  "manifest_version": 3,
  "name": "WebSniper",
  "version": "1.0.0",
  "description": "Capture DOM element data effortlessly.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "WebSniper"
  },
  "side_panel": {
    "default_path": "index.html"
  }
}
